pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/ramadevipanthagadi/project.git'
            }
        }

        stage('Build with Maven') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t onlinebookstore .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 9090:8080 onlinebookstore'
            }
        }

    }
}
